SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Razorpay ─────────────────────────────────────────────────────
# Leave RAZORPAY_KEY_ID blank (or set RAZORPAY_MODE=mock) to enable
# mock checkout — the backend simulates a successful payment so the
# UI flow works without live keys. This is the default for local dev.
#
# For real payments:
#   1. Create a Razorpay account → Dashboard → Settings → API Keys
#   2. Generate a Key ID + Key Secret (Test mode first, then Live)
#   3. Paste them below and set RAZORPAY_MODE=live
#   4. Restart the backend — the wallet UI will show a real Razorpay
#      modal instead of the "Test mode" badge and auto-credit flow.
#
# Billing details (name / email / phone / address) are enforced on
# every real purchase — they're stored once per user in the
# `billing_details` table and reused automatically.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_MODE=mock
